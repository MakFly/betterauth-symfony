{
  "name": "betterauth/symfony-bundle",
  "description": "Symfony bundle for BetterAuth - Modern authentication library",
  "type": "symfony-bundle",
  "license": "MIT",
  "keywords": [
    "symfony",
    "bundle",
    "auth",
    "authentication",
    "oauth",
    "sso",
    "multi-tenant",
    "organizations",
    "betterauth",
    "uuid-v7",
    "api-platform"
  ],
  "authors": [
    {
      "name": "BackToTheFutur Team"
    }
  ],
  "homepage": "https://github.com/betterauth/betterauth-symfony",
  "support": {
    "issues": "https://github.com/betterauth/betterauth-symfony/issues",
    "source": "https://github.com/betterauth/betterauth-symfony"
  },
  "repositories": [
    { "type": "path", "url": "../betterauth-multimodal-php" }
  ],
  "require": {
    "php": "^8.4",
    "api-platform/core": "^4.0",
    "bacon/bacon-qr-code": "^2.0|^3.0",
    "betterauth/multimodal-php": "^0.1 || dev-main",
    "doctrine/doctrine-bundle": "^2.0|^3.0",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.0",
    "monolog/monolog": "^3.0",
    "nelmio/cors-bundle": "^2.0",
    "symfony/asset": "^6.4|^7.0|^8.0",
    "symfony/config": "^6.4|^7.0|^8.0",
    "symfony/console": "^6.4|^7.0|^8.0",
    "symfony/dependency-injection": "^6.4|^7.0|^8.0",
    "symfony/filesystem": "^6.4|^7.0|^8.0",
    "symfony/framework-bundle": "^6.4|^7.0|^8.0",
    "symfony/http-kernel": "^6.4|^7.0|^8.0",
    "symfony/mailer": "^6.4|^7.0|^8.0",
    "symfony/mime": "^6.4|^7.0|^8.0",
    "symfony/property-access": "^6.4|^7.0|^8.0",
    "symfony/property-info": "^6.4|^7.0|^8.0",
    "symfony/security-bundle": "^6.4|^7.0|^8.0",
    "symfony/serializer": "^6.4|^7.0|^8.0",
    "symfony/twig-bundle": "^6.4|^7.0|^8.0",
    "symfony/uid": "^6.4|^7.0|^8.0",
    "symfony/validator": "^6.4|^7.0|^8.0",
    "symfony/yaml": "^6.4|^7.0|^8.0"
  },
  "require-dev": {
    "dg/bypass-finals": "^1.9",
    "doctrine/doctrine-fixtures-bundle": "^4.3",
    "liip/test-fixtures-bundle": "^3.8",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^10.5",
    "symfony/browser-kit": "^6.4|^7.0|^8.0",
    "symfony/debug-bundle": "^6.4|^7.0|^8.0",
    "symfony/http-client": "^6.4|^7.0|^8.0",
    "symfony/maker-bundle": "^1.0",
    "symfony/monolog-bundle": "^3.0",
    "symfony/phpunit-bridge": "^6.4|^7.0|^8.0",
    "symfony/stopwatch": "^6.4|^7.0|^8.0",
    "symfony/web-profiler-bundle": "^6.4|^7.0|^8.0"
  },
  "autoload": {
    "psr-4": {
      "BetterAuth\\Symfony\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BetterAuth\\Symfony\\Tests\\": "tests/",
      "App\\": "tests/App/src/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse --memory-limit=256M",
    "post-install-cmd": [
      "BetterAuth\\Symfony\\Installer\\BundleRegistrar::register"
    ],
    "post-update-cmd": [
      "BetterAuth\\Symfony\\Installer\\BundleRegistrar::register"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "^6.4|^7.0|^8.0"
    },
    "branch-alias": {
      "dev-main": "0.0.x-dev"
    }
  },
  "suggest": {
    "symfony/redis": "For Redis-based rate limiting (recommended for production)",
    "ext-redis": "Redis extension for better performance",
    "ext-apcu": "APCu extension for in-memory caching (development)",
    "geoip2/geoip2": "For IP geolocation in device tracking",
    "mobiledetect/mobiledetectlib": "For device detection in device tracking"
  }
}
